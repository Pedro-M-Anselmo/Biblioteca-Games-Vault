rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuth() && getUserData().role in ['admin', 'superadmin'];
    }

    function isSuperAdmin() {
      return isAuth() && getUserData().role == 'superadmin';
    }

    function isBanned() {
      return isAuth() && getUserData().banned == true;
    }

    // ── USERS ──
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if
        (isAuth() && request.auth.uid == userId &&
          !('role' in request.resource.data) &&
          !('banned' in request.resource.data))
        || (isAdmin() &&
            request.resource.data.role != 'superadmin' &&
            resource.data.role != 'superadmin')
        || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── GAMES ──
    match /games/{gameId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── REVIEWS ──
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && !isBanned() && request.resource.data.userId == request.auth.uid;
      allow update: if
        (isAuth() && !isBanned() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.userId == request.auth.uid)
        || isAdmin();
      allow delete: if
        (isAuth() && resource.data.userId == request.auth.uid)
        || isAdmin();
    }

    // ── CATEGORIES ──
    match /categories/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── PLATFORMS ──
    match /platforms/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
